# AzGallery production environment template
# Copy to .env on the server. Do not commit real secrets.

NODE_ENV=production
HOST=127.0.0.1
PORT=3033

# Public Supabase client values
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Server-only Supabase values
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
AZGALLERY_ADMIN_KEY=replace-with-long-random-admin-key

# Server-only Cloudinary Admin API values
# Used only by server functions to list and import images into AzGallery projects.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
